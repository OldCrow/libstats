+# =============================================================================
+# SIMD COMPILATION FLAGS - TRADITIONAL APPROACH (PHASE 1 FIX)
+# =============================================================================
+# Removed problematic nested generator expressions that cause all flags to be
+# passed to compilers. Using traditional conditionals that are known to work.
+# SIMD source-specific flags are handled by cmake/SIMDDetection.cmake
+
+# MSVC SIMD support (x64 only) - using global flags for compatibility
+if(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC" AND CMAKE_SIZEOF_VOID_P EQUAL 8)
+    # MSVC x64 has AVX2 support by default
+    add_compile_options(/arch:AVX2)
+    add_compile_definitions(
+        LIBSTATS_HAS_AVX2=1
+        LIBSTATS_HAS_AVX=1 
+        LIBSTATS_HAS_SSE2=1
+    )
+    message(STATUS "Applied MSVC x64 SIMD flags: /arch:AVX2 with AVX2/AVX/SSE2 definitions")
+    
+# Clang on Windows (ClangCL) SIMD support
+elseif(CMAKE_CXX_COMPILER_ID MATCHES "Clang" AND WIN32 AND CMAKE_SIZEOF_VOID_P EQUAL 8)
+    add_compile_options(-mavx2)
+    add_compile_definitions(
+        LIBSTATS_HAS_AVX2=1
+        LIBSTATS_HAS_AVX=1
+        LIBSTATS_HAS_SSE2=1
+    )
+    message(STATUS "Applied Clang-cl x64 SIMD flags: -mavx2 with AVX2/AVX/SSE2 definitions")
+
+# Note: GCC and Clang on Unix use source-file-specific SIMD flags via cmake/SIMDDetection.cmake
+# This approach provides better control and avoids the problematic global flag issues
+endif()
+
+# Apply runtime-detected SIMD definitions for GCC/Clang (Unix)
+# These are set by cmake/SIMDDetection.cmake based on actual capability detection
+# The definitions are used by headers for conditional compilation
+# The actual SIMD compilation flags are applied per-source-file to avoid conflicts
 
