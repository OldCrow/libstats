prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: libstats
Description: Modern C++20 statistical distributions library with SIMD and parallel performance
Version: @PROJECT_VERSION@
URL: https://github.com/OldCrow/libstats

Requires:
Libs: -L${libdir} -lstats
Libs.private: @LIBSTATS_PC_LIBS_PRIVATE@
Cflags: -I${includedir} -std=c++20
